<% content_for :title, "#{@designer_name} | Indigo Abyss" %>

<main class="site-shell designer-collection">
  <nav class="collection-breadcrumb" aria-label="Breadcrumb">
    <%= link_to "Home", root_path %>
    <span>/</span>
    <%= link_to "Shop", shop_path %>
    <span>/</span>
    <strong><%= @designer_name %></strong>
  </nav>

  <section class="collection-hero" aria-label="Collection overview">
    <p class="eyebrow">Designer Collection</p>
    <h1><%= @designer_name %></h1>
    <p class="lead">Browse Indigo Abyss picks from <%= @designer_name %> with fit-focused categories and curated stock.</p>
  </section>

  <div class="collection-toolbar" aria-label="Collection toolbar">
    <p><strong><%= @catalog_page.products.length %></strong> products shown</p>
    <div class="collection-toolbar-actions">
      <label for="collection-sort">Sort By</label>
      <select id="collection-sort" disabled>
        <option>Featured</option>
        <option>Price: Low to High</option>
        <option>Price: High to Low</option>
        <option>Newest</option>
      </select>
    </div>
  </div>

  <div class="collection-layout">
    <aside class="collection-sidebar" aria-label="Collection filters">
      <h2>Shop By Category</h2>
      <nav class="category-filters vertical" aria-label="Designer category filters">
        <%= link_to "All", designer_collection_path(@designer_slug, per: params[:per]), class: "pagination-link #{'active' if @selected_category.blank?}" %>
        <% @categories.each do |category| %>
          <% label = category.capitalize %>
          <%= link_to label, designer_collection_path(@designer_slug, category: category, per: params[:per]), class: "pagination-link #{'active' if @selected_category == category}" %>
        <% end %>
      </nav>
    </aside>

    <section class="collection-main" aria-label="Designer products">
      <% if @catalog_page.empty? %>
        <section class="empty-state" aria-live="polite">
          <h2>No products available yet</h2>
          <p>
            <%= @selected_category.present? ? "No #{@designer_name} products found in #{@selected_category.capitalize}." : "No products found for this designer yet." %>
          </p>
          <%= link_to "Browse All Products", shop_path, class: "pagination-link" %>
        </section>
      <% else %>
        <section class="product-grid" aria-label="Designer products grid">
          <% @catalog_page.products.each do |product| %>
            <%= link_to product_path(product.handle || product.id), class: "product-card-link", aria: { label: "View #{product.title}" } do %>
              <article class="product-card">
                <div class="product-media">
                  <img class="product-image product-image-primary" src="<%= product.image_url %>" alt="<%= product.title %>" loading="lazy">
                  <img class="product-image product-image-secondary" src="<%= product.secondary_image_url %>" alt="" aria-hidden="true" loading="lazy">
                </div>
                <div class="product-body">
                  <h3><%= product.title %></h3>
                  <p class="product-designer"><%= product_designer_label(product) %></p>
                  <p class="product-description"><%= product.description %></p>
                  <p class="product-category">Style: <%= product_style_label(product) %></p>
                  <p class="price"><%= product_card_price(product) %></p>
                </div>
              </article>
            <% end %>
          <% end %>
        </section>

        <nav class="pagination-nav" aria-label="Collection pagination">
          <% if @catalog_page.prev_cursor.present? %>
            <%= link_to "Previous", designer_collection_path(@designer_slug, before: @catalog_page.prev_cursor, per: params[:per], category: @selected_category), class: "pagination-link" %>
          <% else %>
            <span class="pagination-link disabled" aria-disabled="true">Previous</span>
          <% end %>

          <% if @catalog_page.next_cursor.present? %>
            <%= link_to "Next", designer_collection_path(@designer_slug, after: @catalog_page.next_cursor, per: params[:per], category: @selected_category), class: "pagination-link" %>
          <% else %>
            <span class="pagination-link disabled" aria-disabled="true">Next</span>
          <% end %>
        </nav>
      <% end %>
    </section>
  </div>
</main>
